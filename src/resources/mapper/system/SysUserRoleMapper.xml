<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cui.edu.system.mapper.SysUserRoleMapper">

    <select id="findRoleMenus" resultType="com.cui.edu.system.entity.SysMenu">
        select
            sm.*
        from
            sys_role_menu srm
                inner join sys_role sr on
                sr.id = srm.role_id
                inner join sys_menu sm on
                srm.menu_id = sm.id
        where
            sr.id = #{roleId}
    </select>
</mapper>
